# Copy this file to .env and replace placeholders locally. Never commit .env.
DB_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=6380
DEVICE_CODE=gate-device-1
DEVICE_SECRET=replace-with-level4-device-secret
DEVICE_STATION_CODE=station-1
DEVICE_PACKAGE_EXCHANGE=afc.exchange
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_SSL_ENABLED=false

# Backend settings used when running outside Docker.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:15432/ticket_app
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=replace-with-a-strong-database-password
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DATABASE=0

# Generate a long random value; do not reuse this placeholder.
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes-long
JWT_EXPIRATION_SECONDS=86400

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=replace-with-an-app-password
MAIL_FROM=your-email@example.com

LEVEL5_BASE_URL=http://localhost:8082
LEVEL5_TICKET_PURCHASE_PATH=/api/tickets/purchase
LEVEL5_SINGLE_TRIP_TICKET_PURCHASE_PATH=/api/tickets/single-trip
LEVEL5_PASS_TICKET_PURCHASE_PATH=/api/tickets/pass
LEVEL5_CARD_PURCHASE_PATH=/api/cards/purchase
LEVEL5_PASSENGER_STATIONS_PATH=/api/passenger/stations
LEVEL5_PASSENGER_ROUTES_PATH=/api/passenger/routes
LEVEL5_PASSENGER_CARDS_PATH=/api/passengers/{userId}/cards
LEVEL5_PASSENGER_TICKETS_PATH=/api/passengers/{userId}/tickets
LEVEL5_PASSENGER_TRIPS_PATH=/api/passengers/{userId}/trips
LEVEL5_FARE_PRICES_PATH=/api/passenger/fare/prices
LEVEL5_FARE_DISCOUNTS_PATH=/api/passenger/fare/discounts
LEVEL5_MOCK_ENABLED=false
CATALOG_REFRESH_TTL_SECONDS=600

LEVEL4_BASE_URL=http://localhost:8083
VALIDATION_LEVEL4_BASE_URL=http://host.docker.internal:8083
LEVEL4_QR_CODE_PATH=/vdt/generate-dynamic-qr
LEVEL4_SCAN_RECORD_BATCH_PATH=/vdt/transaction/submit-batch
LEVEL4_MOCK_ENABLED=false

VALIDATION_SERVICE_PORT=8081
VALIDATION_DATASOURCE_URL=jdbc:postgresql://localhost:15432/validation-gate
VALIDATION_DATASOURCE_USERNAME=postgres
VALIDATION_DB_PASSWORD=replace-with-a-strong-database-password
VALIDATION_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173
VALIDATION_ALLOWED_ORIGIN_PATTERNS=http://localhost:*
