# Copy this file to .env and replace placeholders locally. Never commit .env.
DB_PASSWORD=replace-with-a-strong-database-password

# Backend settings used when running outside Docker.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ticket_app
SPRING_DATASOURCE_USERNAME=postgres
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Generate a long random value; do not reuse this placeholder.
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes-long
JWT_EXPIRATION_SECONDS=86400

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=replace-with-an-app-password
MAIL_FROM=your-email@example.com

LEVEL5_BASE_URL=http://localhost:8082
LEVEL5_TICKET_PURCHASE_PATH=/api/tickets/purchase
LEVEL5_CARD_PURCHASE_PATH=/api/cards/purchase
LEVEL5_TICKET_HISTORY_PATH=/api/users/{accountId}/tickets/history
LEVEL5_CARD_HISTORY_PATH=/api/users/{accountId}/cards
LEVEL5_TRAVEL_HISTORY_PATH=/api/accounts/{accountId}/travels
LEVEL5_TICKET_TYPES_PATH=/api/tickets/types
LEVEL5_CARD_TYPES_PATH=/api/cards/packages
LEVEL5_MOCK_ENABLED=false
CATALOG_REFRESH_TTL_SECONDS=600

LEVEL4_BASE_URL=https://level4.example
LEVEL4_QR_CODE_PATH=/qr-codes
LEVEL4_SCAN_RECORD_BATCH_PATH=/scan-record/batch
LEVEL4_MOCK_ENABLED=true

VALIDATION_SERVICE_PORT=8081
VALIDATION_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ticket_app
VALIDATION_DATASOURCE_USERNAME=postgres
VALIDATION_DB_PASSWORD=replace-with-a-strong-database-password
VALIDATION_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
