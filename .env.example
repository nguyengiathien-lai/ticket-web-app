# Copy this file to .env and replace placeholders locally. Never commit .env.
DB_PASSWORD=replace-with-a-strong-database-password

# Backend settings used when running outside Docker.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ticket_app
SPRING_DATASOURCE_USERNAME=postgres
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Generate a long random value; do not reuse this placeholder.
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes-long
JWT_EXPIRATION_SECONDS=86400

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=replace-with-an-app-password
MAIL_FROM=your-email@example.com

EXTERNAL_TICKET_BASE_URL=https://higher-system.example
EXTERNAL_TICKET_REQUEST_PATH=/api/tickets/request
EXTERNAL_SCAN_RECORD_PATH=/scan-record
EXTERNAL_TICKET_MOCK_ENABLED=true
